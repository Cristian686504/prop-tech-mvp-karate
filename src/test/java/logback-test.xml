<?xml version="1.0" encoding="UTF-8"?>
<!--
    logback-test.xml  â€“  ConfiguraciÃ³n de logging para Karate
    Niveles recomendados:
      DEBUG  â†’ muestra request/response completos (Ãºtil al desarrollar)
      INFO   â†’ solo resultados (recomendado para CI/CD)
-->
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Cambiar a DEBUG para ver los HTTP request/response completos -->
    <logger name="com.intuit.karate" level="INFO"/>
    <logger name="io.karatelabs"     level="INFO"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
